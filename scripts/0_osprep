#!/bin/bash
set -euo pipefail

# Update and install OS packages
apt-get update
apt-get upgrade -y
apt-get install -y --no-install-recommends \
    build-essential procps curl file \
    git sudo jq libglib2.0-dev zip vim \
    shellcheck ldap-utils \
    bash-completion wget \
    python3-pip ca-certificates gnupg

# Install Node.js LTS (for Claude CLI)
curl -fsSL https://deb.nodesource.com/setup_lts.x | bash -
apt-get install -y --no-install-recommends nodejs

# Clean up
apt-get clean
rm -rf /var/lib/apt/lists/*

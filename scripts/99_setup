#!/bin/bash
set -euo pipefail

# Git setup
git config --global user.email "hvetsa@yahoo.com"
git config --global user.name "Hari Vetsa"

# SSH key (mount /Documents/secure_zone at runtime)
mkdir -p /root/.ssh
echo 'IdentityFile /Documents/secure_zone/.ssh/id_rsa' > /root/.ssh/config
chmod 600 /root/.ssh/config

# Claude CLI
npm install -g @anthropic-ai/claude-code
